<view class="container">
  <view class="calculator-card">
    <text class="title">{{motto}}</text>
    <input class="score-input" type="number" placeholder="请输入平时成绩" value="{{usualScore}}" bindinput="onUsualInput" />
    <input class="score-input" type="number" placeholder="请输入期末成绩" value="{{finalScore}}" bindinput="onFinalInput" />

    <view class="weight-section">
      <text class="weight-title">成绩权重</text>

      <input class="score-input" type="number" placeholder="平时成绩权重" value="{{usualWeight}}" bindinput="onUsualWeightInput" />

      <input class="score-input" type="number" placeholder="期末成绩权重" value="{{finalWeight}}" bindinput="onFinalWeightInput" />
    </view>

    <button class="calculator-button" bindtap="calculateScore">
      计算总成绩
    </button>

    <button class="clear-button" bindtap="clearForm">
      清空重填
    </button>

    <view wx:if="{{totalScore !== ''}}" class="result-card">

      <text class="result-score">
        总成绩：{{totalScore}}
      </text>

      <text class="grade-text {{totalScore >= 60 ? 'pass' : 'fail'}}">
        成绩等级：{{gradeLevel}}
      </text>
    </view>
  </view>
</view>